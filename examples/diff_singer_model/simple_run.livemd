## Build Pipeline and Prepare to Demo

```elixir
defmodule Orchid.Livebook.GanttTracker do
  use Agent

  def start_link(_) do
    Agent.start_link(fn ->[] end, name: __MODULE__)
  end

  def handle_event([:orchid, :step, :start], measurements, meta, _config) do
    start_ms = System.convert_time_unit(measurements.system_time, :native, :microsecond) / 1000.0
    
    Agent.update(__MODULE__, fn state -> 
      [{meta, :start, start_ms} | state]
    end)
  end

  def handle_event([:orchid, :step, status], measurements, meta, _config) 
      when status in [:done, :exception, :special] do
    duration_ms = System.convert_time_unit(measurements.duration, :native, :microsecond) / 1000.0

    Agent.update(__MODULE__, fn state ->[{meta, status, duration_ms} | state]
    end)
  end

  def get_spans() do
    events = Agent.get(__MODULE__, & &1) |> Enum.reverse()

    {_, spans} = Enum.reduce(events, {%{},[]}, fn 
      {meta, :start, start_ms}, {pending, spans} ->
        sig = {meta.impl, meta.in_keys, meta.out_keys}
        {Map.put(pending, sig, {start_ms, meta}), spans}

      {meta, status, duration_ms}, {pending, spans} ->
        sig = {meta.impl, meta.in_keys, meta.out_keys}
        case Map.pop(pending, sig) do
          {{start_ms, _meta}, new_pending} ->
            impl_name = 
              if is_function(meta.impl) do
                "Anonymous Function"
              else
                inspect(meta.impl) |> String.split(".") |> List.last()
              end
            span = %{
              step: "#{impl_name}",
              start: start_ms,
              end: start_ms + duration_ms,
              visual_end: start_ms + max(duration_ms, 10.0),
              duration: duration_ms,
              status: status
            }

            {new_pending,[span | spans]}
          {nil, ^pending} ->
            {pending, spans}
        end
    end)
    spans
  end

  def clear(), do: Agent.update(__MODULE__, fn _ ->[] end)
end
```

